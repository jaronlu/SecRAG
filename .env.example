# 复制为 .env 并填入真实值：cp .env.example .env

# App
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=["*"]

# LLM provider 切换："openai"（OpenAI 兼容接口，如 StepFun/DeepSeek）或 "ollama"（本地模型）
LLM_PROVIDER=openai

# provider=ollama 时生效
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.1

# provider=openai 时生效
OPENAI_API_BASE=https://api.stepfun.com/step_plan/v1
OPENAI_MODEL=step-3.7-flash
# 必填：provider=openai 时若为空会在启动时报错
OPENAI_API_KEY=

# Embedding
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma
